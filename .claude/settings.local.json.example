{
  "_comment": "Copy this file to .claude/settings.local.json and replace the placeholder with your real Notion integration key. settings.local.json is gitignored and merges over settings.json, so the real key never enters the repo.",
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "@notionhq/notion-mcp-server"],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer YOUR_NOTION_API_KEY\", \"Notion-Version\": \"2022-06-28\"}"
      }
    }
  }
}
